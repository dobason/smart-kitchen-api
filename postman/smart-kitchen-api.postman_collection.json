{
  "info": {
    "name": "Smart Kitchen API",
    "description": "Collection test nhanh cho Swagger/Postman. Chỉnh baseUrl, userId, recipeId, cookbookId, ingredientId, tagId theo dữ liệu thực tế trong DB trước khi chạy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "recipeId",
      "value": "1"
    },
    {
      "key": "cookbookId",
      "value": "1"
    },
    {
      "key": "ingredientId",
      "value": "1"
    },
    {
      "key": "tagId",
      "value": "1"
    },
    {
      "key": "stepId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Get all users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/users"
          }
        },
        {
          "name": "Get user by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/users/{{userId}}"
          }
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"chef@example.com\",\n  \"passwordHash\": \"hashed-password\",\n  \"username\": \"chef01\",\n  \"avartarUrl\": \"https://example.com/avatar.jpg\"\n}"
            },
            "url": "{{baseUrl}}/v1/users"
          }
        }
      ]
    },
    {
      "name": "Cookbooks",
      "item": [
        {
          "name": "Get cookbooks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/cookbooks"
          }
        },
        {
          "name": "Filter cookbooks by userId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/cookbooks?userId={{userId}}"
          }
        },
        {
          "name": "Create cookbook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bữa tối gia đình\",\n  \"userId\": {{userId}}\n}"
            },
            "url": "{{baseUrl}}/v1/cookbooks"
          }
        }
      ]
    },
    {
      "name": "Recipes",
      "item": [
        {
          "name": "Get recipes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/recipes"
          }
        },
        {
          "name": "Filter recipes by userId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/recipes?userId={{userId}}"
          }
        },
        {
          "name": "Filter recipes by sourceType",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/recipes?sourceType=MANUAL"
          }
        },
        {
          "name": "Create recipe",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"recipesName\": \"Canh chua cá\",\n  \"description\": \"Món canh chua miền Nam\",\n  \"totalTime\": 45,\n  \"calories\": 350,\n  \"protein\": 25,\n  \"carbs\": 18,\n  \"fats\": 12,\n  \"sourceType\": \"MANUAL\",\n  \"numberOfServes\": 4\n}"
            },
            "url": "{{baseUrl}}/v1/recipes"
          }
        }
      ]
    },
    {
      "name": "Steps",
      "item": [
        {
          "name": "Get steps",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/steps"
          }
        },
        {
          "name": "Filter steps by recipeId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/steps?recipeId={{recipeId}}"
          }
        },
        {
          "name": "Create step",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipeId\": {{recipeId}},\n  \"stepNumber\": 1,\n  \"instruction\": \"Sơ chế nguyên liệu\",\n  \"tip\": \"Rửa sạch rau trước khi cắt\",\n  \"time\": 10\n}"
            },
            "url": "{{baseUrl}}/v1/steps"
          }
        }
      ]
    },
    {
      "name": "Ingredients",
      "item": [
        {
          "name": "Get ingredients",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/ingredients"
          }
        },
        {
          "name": "Create ingredient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cà chua\",\n  \"icon\": \"https://example.com/tomato.png\"\n}"
            },
            "url": "{{baseUrl}}/v1/ingredients"
          }
        }
      ]
    },
    {
      "name": "Recipe Ingredients",
      "item": [
        {
          "name": "Get recipe ingredients",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/recipe-ingredients"
          }
        },
        {
          "name": "Filter recipe ingredients by recipeId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/recipe-ingredients?recipeId={{recipeId}}"
          }
        },
        {
          "name": "Filter recipe ingredients by ingredientId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/recipe-ingredients?ingredientId={{ingredientId}}"
          }
        },
        {
          "name": "Create recipe ingredient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipeId\": {{recipeId}},\n  \"ingredientId\": {{ingredientId}},\n  \"quantity\": 2,\n  \"unit\": \"quả\",\n  \"note\": \"Cắt múi cau\"\n}"
            },
            "url": "{{baseUrl}}/v1/recipe-ingredients"
          }
        }
      ]
    },
    {
      "name": "Tags",
      "item": [
        {
          "name": "Get tags",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/tags"
          }
        },
        {
          "name": "Create tag",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Món Việt\",\n  \"category\": \"Cuisine\"\n}"
            },
            "url": "{{baseUrl}}/v1/tags"
          }
        }
      ]
    },
    {
      "name": "Recipe Tags",
      "item": [
        {
          "name": "Get recipe tags",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/recipe-tags"
          }
        },
        {
          "name": "Filter recipe tags by recipeId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/recipe-tags?recipeId={{recipeId}}"
          }
        },
        {
          "name": "Filter recipe tags by tagId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/recipe-tags?tagId={{tagId}}"
          }
        }
      ]
    },
    {
      "name": "Cookbook Recipes",
      "item": [
        {
          "name": "Get cookbook recipes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/cookbook-recipes"
          }
        },
        {
          "name": "Filter cookbook recipes by cookbookId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/cookbook-recipes?cookbookId={{cookbookId}}"
          }
        },
        {
          "name": "Filter cookbook recipes by recipeId",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/cookbook-recipes?recipeId={{recipeId}}"
          }
        }
      ]
    }
  ]
}